#!/bin/sh

case "$1" in
    --s1)
        dir=$DATADIR/sonic1
        shift # Remove --s1 from arguments
        ;;
    --s2)
        dir=$DATADIR/sonic2
        shift # Remove --s2 from arguments
        ;;
    *)
        # Default: No flag, use the base folder
        dir=$DATADIR/rsdkv4
        ;;
esac
mkdir -p "$dir"
cd "$dir"
